@{
    ViewData["Title"] = "Từ chối truy cập";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <!-- Icon -->
            <div class="mb-4">
                <i class="fas fa-ban text-danger" style="font-size: 80px;"></i>
            </div>

            <!-- Mã lỗi -->
            <h1 class="display-1 fw-bold text-danger">403</h1>
            <h2 class="mb-4">🚫 TỪ CHỐI TRUY CẬP</h2>

            <!-- Thông báo chi tiết -->
            <div class="card shadow mb-4">
                <div class="card-body">
                    <p class="lead">
                        <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                        Bạn không có quyền truy cập vào khu vực này!
                    </p>
                    <hr />
                    <p class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Vui lòng liên hệ với <strong>Quản trị viên</strong> để được cấp quyền truy cập.
                    </p>
                    <p class="text-muted small">
                        <i class="fas fa-shield-alt me-1"></i>
                        Vai trò hiện tại của bạn:
                        <strong class="text-primary">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</strong>
                    </p>
                </div>
            </div>

            <!-- Nút điều hướng -->
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg me-2">
                    <i class="fas fa-home me-2"></i> Về trang chủ
                </a>
                <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
    }

    .btn {
        border-radius: 10px;
        padding: 10px 25px;
    }
</style>