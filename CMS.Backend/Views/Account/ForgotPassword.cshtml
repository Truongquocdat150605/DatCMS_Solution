@{
    Layout = "_Layout";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - CMS Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(120deg, #4e73df 0%, #224abe 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .box {
            width: 100%;
            max-width: 560px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.18);
            padding: 28px;
        }

        .step-title {
            color: #224abe;
            font-weight: 700;
        }

        .hint {
            color: #6c757d;
        }

        .hidden {
            display: none;
        }
    </style>
</head>
<body>
    <div class="box">
        <div class="text-center mb-4">
            <i class="fas fa-unlock-keyhole fa-3x text-primary"></i>
            <h3 class="mt-3">Khôi phục mật khẩu Admin</h3>
            <p class="hint mb-0">Dành cho Admin/Editor của CMS</p>
        </div>

        <div id="alertBox" class="alert hidden" role="alert"></div>

        <form id="requestOtpForm">
            <h5 class="step-title mb-3">Bước 1: Gửi OTP</h5>
            <div class="mb-3">
                <label class="form-label">Tên đăng nhập</label>
                <input type="text" name="username" class="form-control" placeholder="admin" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email quản trị</label>
                <input type="email" name="email" class="form-control" placeholder="admin@cms.local" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-paper-plane me-2"></i>Gửi OTP
            </button>
        </form>

        <hr class="my-4" />

        <form id="resetForm" class="hidden">
            <h5 class="step-title mb-3">Bước 2: Đặt lại mật khẩu</h5>
            <input type="hidden" name="username" />
            <input type="hidden" name="email" />
            <div class="mb-3">
                <label class="form-label">OTP</label>
                <input type="text" name="otp" class="form-control" placeholder="Nhập mã OTP" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu mới</label>
                <input type="password" name="newPassword" class="form-control" placeholder="********" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Xác nhận mật khẩu mới</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="********" required />
            </div>
            <button type="submit" class="btn btn-success w-100">
                <i class="fas fa-lock-open me-2"></i>Đặt lại mật khẩu
            </button>
        </form>

        <div class="text-center mt-4">
            <a href="/Account/Login" class="text-decoration-none">Quay về đăng nhập</a>
        </div>
    </div>

    <script>
        (function () {
            const alertBox = document.getElementById('alertBox');
            const requestOtpForm = document.getElementById('requestOtpForm');
            const resetForm = document.getElementById('resetForm');

            function showAlert(type, message) {
                alertBox.className = `alert alert-${type}`;
                alertBox.textContent = message;
                alertBox.classList.remove('hidden');
            }

            requestOtpForm?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const formData = new FormData(requestOtpForm);
                const payload = {
                    username: formData.get('username')?.toString().trim() || '',
                    email: formData.get('email')?.toString().trim() || ''
                };

                try {
                    const res = await fetch('/Account/SendResetOtp', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await res.json().catch(() => ({}));
                    if (!res.ok || !data.success) {
                        showAlert('danger', data.message || 'Không gửi được OTP.');
                        return;
                    }

                    showAlert('success', data.message || 'Đã gửi OTP.');
                    resetForm.classList.remove('hidden');
                    resetForm.username.value = payload.username;
                    resetForm.email.value = payload.email;
                } catch (err) {
                    showAlert('danger', 'Lỗi hệ thống, vui lòng thử lại.');
                }
            });

            resetForm?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const formData = new FormData(resetForm);
                const payload = {
                    username: formData.get('username')?.toString().trim() || '',
                    email: formData.get('email')?.toString().trim() || '',
                    otp: formData.get('otp')?.toString().trim() || '',
                    newPassword: formData.get('newPassword')?.toString().trim() || '',
                    confirmPassword: formData.get('confirmPassword')?.toString().trim() || ''
                };

                if (payload.newPassword !== payload.confirmPassword) {
                    showAlert('danger', 'Mật khẩu xác nhận không khớp.');
                    return;
                }

                try {
                    const res = await fetch('/Account/ResetPassword', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await res.json().catch(() => ({}));
                    if (!res.ok || !data.success) {
                        showAlert('danger', data.message || 'Đặt lại mật khẩu thất bại.');
                        return;
                    }

                    showAlert('success', data.message || 'Đổi mật khẩu thành công.');
                    setTimeout(() => window.location.href = '/Account/Login', 1200);
                } catch (err) {
                    showAlert('danger', 'Lỗi hệ thống, vui lòng thử lại.');
                }
            });
        })();
    </script>
</body>
</html>
