@model CMS.Data.Entities.Advertisement

@{
    ViewData["Title"] = "Thêm Banner mới";
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Thêm Banner/Quảng cáo mới</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">Tiêu đề Banner <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="Ví dụ: Sale mùa hè 50%" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold">Đường dẫn Hình ảnh (URL) <span class="text-danger">*</span></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="Ví dụ: images/banners/banner1.png" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <small class="text-muted">Nhập URL đầy đủ hoặc đường dẫn tương đối từ Frontend (vd: images/banners/xxx.jpg)</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LinkUrl" class="form-label fw-bold">Link khi click vào Banner (Tùy chọn)</label>
                        <input asp-for="LinkUrl" class="form-control" placeholder="Ví dụ: /products?categoryId=1" />
                        <span asp-validation-for="LinkUrl" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 bg-light p-3 mb-3">
                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label fw-bold">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                            <small class="text-muted">Số càng nhỏ hiển thị càng trước</small>
                        </div>

                        <div class="form-check form-switch mb-3 mt-3">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch">
                            <label class="form-check-label fw-bold" for="isActiveSwitch">Kích hoạt hiển thị</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 border-top pt-3">
                <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu lại</button>
                <a asp-action="Index" class="btn btn-secondary ms-2"><i class="bi bi-x-circle"></i> Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
