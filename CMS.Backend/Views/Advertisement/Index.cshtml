@model IEnumerable<CMS.Data.Entities.Advertisement>

@{
    ViewData["Title"] = "Quản lý Banner/Quảng cáo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary"><i class="bi bi-images"></i> Quản lý Banner/Quảng cáo</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm banner mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width: 80px;">STT</th>
                        <th class="text-center" style="width: 200px;">Hình ảnh</th>
                        <th>Tiêu đề</th>
                        <th class="text-center">Thứ tự</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center align-middle">@(stt++)</td>
                                <td class="text-center align-middle">
                                    <img src="@(item.ImageUrl.StartsWith("http") ? item.ImageUrl : "http://localhost:3000/" + item.ImageUrl)" alt="@item.Title" style="max-height: 80px; max-width: 180px; object-fit: contain;" />
                                </td>
                                <td class="align-middle">
                                    <strong>@item.Title</strong><br/>
                                    @if(!string.IsNullOrEmpty(item.LinkUrl)) {
                                        <a href="@item.LinkUrl" target="_blank" class="small text-muted">@item.LinkUrl</a>
                                    }
                                </td>
                                <td class="text-center align-middle">@item.DisplayOrder</td>
                                <td class="text-center align-middle">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Đang hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã ẩn</span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Sửa"><i class="bi bi-pencil-square"></i> Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" title="Xóa" onclick="return confirm('Bạn có chắc muốn xóa banner này?');"><i class="bi bi-trash"></i> Xóa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Chưa có banner nào. Hãy thêm mới!</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
