@model IEnumerable<CMS.Data.Entities.Category>
@* /* * Sinh viên: Trương Quốc Đạt - 2123110209
   * Trang danh sách chuyên mục bài viết */ *@

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">DANH SÁCH CHUYÊN MỤC BÀI VIẾT</h2>
        <a asp-action="Create" class="btn btn-primary">Thêm chuyên mục mới</a>
    </div>

    @* ĐẠT NHỚ THÊM ĐOẠN NÀY ĐỂ HIỂN THỊ LỖI KHI XÓA KHÔNG THÀNH CÔNG *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Thông báo:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr class="text-center">
                <th>ID</th>
                <th>Tên chuyên mục</th>
                <th>Mô tả</th>
                <th style="width: 200px">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">@item.Id</td>
                    <td><b>@item.Name</b></td>
                    <td>@item.Description</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>

                        @* Nút xóa gọi đến hàm Delete trong Controller đã có check bài viết con *@
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('M có chắc muốn xóa danh mục này không? Lưu ý: Nếu có bài viết bên trong sẽ không xóa được.')">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>