@model IEnumerable<CMS.Data.Entities.CategoryProduct>
@* /* * Người thực hiện: Trương Quốc Đạt - 2123110209
 * Mô tả: Danh sách danh mục sản phẩm có xử lý hiển thị lỗi ràng buộc.
 */ *@

@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">BÀI TẬP 3: DANH MỤC SẢN PHẨM</h2>
        <a asp-action="Create" class="btn btn-primary">Thêm danh mục SP mới</a>
    </div>

    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    @* ĐƯA THÔNG BÁO LỖI RA NGOÀI TABLE ĐỂ GIAO DIỆN CHUẨN *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark text-center">
            <tr>
                <th style="width: 10%">ID</th>
                <th style="width: 30%">Tên danh mục sản phẩm</th>
                <th style="width: 25%">Ảnh</th>
                <th style="width: 35%">Mô tả</th>
                <th style="width: 20%">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center">Chưa có danh mục nào.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@item.Id</td>
                        <td><b>@item.Name</b></td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" width="70" class="rounded shadow-sm" alt="@item.Name" />
                            }
                            else
                            {
                                <i class="text-muted">No Image</i>
                            }
                        </td>
                        <td>@item.Description</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('M có chắc muốn xóa không? Nếu danh mục có sản phẩm sẽ không xóa được đâu!')">Xóa</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>