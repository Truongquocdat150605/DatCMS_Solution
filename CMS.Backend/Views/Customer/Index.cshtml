@model IEnumerable<CMS.Data.Entities.Customer>
/* * Sinh viên: Trương Quốc Đạt - 2123110209 */

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">BÀI TẬP 5: DANH SÁCH KHÁCH HÀNG</h2>
        <a asp-action="Create" class="btn btn-primary">Thêm khách hàng mới</a>
    </div>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">Chưa có dữ liệu khách hàng.</div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark text-center">
                <tr>
                    <th>ID</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Địa chỉ</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr>
                        <td class="text-center">@customer.Id</td>
                        <td>@customer.FullName</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Address</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@customer.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Xóa khách hàng này?')">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>