@model IEnumerable<CMS.Data.Entities.Customer>

@{
    ViewData["Title"] = "Danh sách khách hàng";
}

<div class="container mt-4">
    <h2 class="text-primary">BÀI TẬP 5: DANH SÁCH KHÁCH HÀNG (CUSTOMERS)</h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            Chưa có dữ liệu trong bảng Customers. Vui lòng nhập dữ liệu mẫu trong SSMS.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Địa chỉ</th>
                    <!-- Không hiển thị Password vì lý do bảo mật -->
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr>
                        <td>@customer.Id</td>
                        <td>@customer.FullName</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Address</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3 alert alert-info">
            <strong>Lưu ý:</strong> Mật khẩu không được hiển thị vì lý do bảo mật.
        </div>
    }
</div>