@{
    ViewData["Title"] = "Trang chủ Quản trị";
}

@* /* * Sinh viên thực hiện: Trương Quốc Đạt
   * MSSV: 2123110209
   * Chức năng: Dashboard tổng quan hệ thống CMS
 */ *@

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 text-primary font-weight-bold">HỆ THỐNG QUẢN TRỊ CMS</h1>
        <p class="lead">Chào mừng <b>Trương Quốc Đạt</b> trở lại bảng điều khiển.</p>
        <hr style="width: 20%; border: 2px solid #007bff;" />
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Sản phẩm</h5>
                            <p class="card-text">Quản lý kho hàng</p>
                        </div>
                        <i class="fas fa-box-open fa-2x"></i>
                    </div>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-sm mt-3 w-100">Xem chi tiết</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Bài viết</h5>
                            <p class="card-text">Tin tức & Sự kiện</p>
                        </div>
                        <i class="fas fa-newspaper fa-2x"></i>
                    </div>
                    <a asp-controller="Post" asp-action="Index" class="btn btn-light btn-sm mt-3 w-100">Xem chi tiết</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Khách hàng</h5>
                            <p class="card-text">Thông tin liên hệ</p>
                        </div>
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                    <a asp-controller="Customer" asp-action="Index" class="btn btn-light btn-sm mt-3 w-100">Xem chi tiết</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Danh mục</h5>
                            <p class="card-text">Phân loại hệ thống</p>
                        </div>
                        <i class="fas fa-list fa-2x"></i>
                    </div>
                    <a asp-controller="CategoryProduct" asp-action="Index" class="btn btn-dark btn-sm mt-3 w-100">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <h5 class="font-weight-bold text-primary text-uppercase mb-1">Thông tin đồ án Buổi 02</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><b>Họ tên:</b> Trương Quốc Đạt</li>
                        <li class="list-group-item"><b>MSSV:</b> 2123110209</li>
                        <li class="list-group-item"><b>Chuyên ngành:</b> An ninh mạng (Cyber Security)</li>
                        <li class="list-group-item"><b>Trạng thái hệ thống:</b> <span class="badge bg-success">Đang hoạt động tốt</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>