@model IEnumerable<CMS.Data.Entities.Order>

@{
    ViewData["Title"] = "Danh sách đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">DANH SÁCH ĐƠN HÀNG (ORDERS)</h2>
        <a asp-action="Create" class="btn btn-primary">Thêm đơn hàng mới</a>
    </div>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    <!-- FORM TÌM KIẾM VÀ LỌC -->
    <form method="get" asp-action="Index" class="mb-4 p-3 border rounded bg-light">
        <div class="row">
            <div class="col-md-5">
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm theo tên khách hàng..." />
            </div>
            <div class="col-md-4">
                <select name="status" class="form-select">
                    <option value="">-- Tất cả trạng thái --</option>
                    @if (ViewBag.StatusFilter != null && (int)ViewBag.StatusFilter == 0) { <option value="0" selected>Chờ duyệt</option> } else { <option value="0">Chờ duyệt</option> }
                    @if (ViewBag.StatusFilter != null && (int)ViewBag.StatusFilter == 1) { <option value="1" selected>Đang giao</option> } else { <option value="1">Đang giao</option> }
                    @if (ViewBag.StatusFilter != null && (int)ViewBag.StatusFilter == 2) { <option value="2" selected>Đã xong</option> } else { <option value="2">Đã xong</option> }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-success w-100"><i class="bi bi-search"></i> Tìm kiếm & Lọc</button>
            </div>
        </div>
    </form>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            Chưa có dữ liệu trong bảng Orders. Vui lòng thêm dữ liệu.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Mã đơn hàng</th>
                    <th>Ngày đặt</th>
                    <th>Khách hàng</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    string statusText = order.Status switch
                    {
                        0 => "Chờ duyệt",
                        1 => "Đang giao",
                        2 => "Đã xong",
                        _ => "Không xác định"
                    };

                    string statusClass = order.Status switch
                    {
                        0 => "bg-warning",
                        1 => "bg-info",
                        2 => "bg-success",
                        _ => "bg-secondary"
                    };

                    <tr>
                        <td>@order.Id</td>
                        <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@order.Customer?.FullName</td>
                        <td><span class="badge @statusClass">@statusText</span></td>
                        <td>@(string.IsNullOrEmpty(order.Notes) ? "Không có" : order.Notes)</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@order.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('M có chắc muốn xóa đơn hàng này không?')">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>