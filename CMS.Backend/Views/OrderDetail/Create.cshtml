@model CMS.Data.Entities.OrderDetail

@{
    ViewData["Title"] = "Thêm Chi tiết đơn hàng";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4">Thêm chi tiết đơn hàng</h2>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div class="mb-3">
                    <label class="form-label">Mã đơn hàng</label>
                    <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId"></select>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Sản phẩm</label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Số lượng</label>
                    <input asp-for="Quantity" type="number" min="1" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Đơn giá</label>
                    <input asp-for="UnitPrice" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>
