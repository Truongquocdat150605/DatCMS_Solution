@model IEnumerable<CMS.Data.Entities.OrderDetail>

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">QUẢN LÝ CHI TIẾT ĐƠN HÀNG</h2>
        <a asp-action="Create" class="btn btn-primary">Thêm chi tiết</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            Chưa có dữ liệu. Vui lòng thêm chi tiết đơn hàng.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Mã Đơn hàng</th>
                    <th>Sản phẩm</th>
                    <th>Số lượng</th>
                    <th>Đơn giá</th>
                    <th>Thành tiền</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>#@item.OrderId</td>
                        <td>@(item.Product?.Name ?? "N/A")</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                        <td>@((item.Quantity * item.UnitPrice).ToString("N0")) VNĐ</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bạn có chắc muốn xóa chi tiết này không?')">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
