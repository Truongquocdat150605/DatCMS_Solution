 * Tên file: Edit.cshtml
 * Mô tả: Giao diện chỉnh sửa bài viết - Có tích hợp CKEditor với Upload Ảnh.
 *@

@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">
    <h2 class="text-warning text-uppercase">CHỈNH SỬA BÀI VIẾT</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="post-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Chuyên mục</label>
                    <select asp-for="CategoryId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.CategoryId, "Id", "Name"))">
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Hình ảnh hiện tại</label>
                    <div class="mb-2">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" width="150" class="img-thumbnail" />
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                    </div>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Nội dung</label>
                    @* Giá trị Content hiện tại sẽ được load vào CKEditor *@
                    <textarea asp-for="Content" id="editor-content" class="form-control" rows="8"></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary">Huỷ bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
    <script>
        class MyUploadAdapter {
            constructor(loader) {
                this.loader = loader;
                this.url = 'https://localhost:7048/api/UploadApi/ckeditor';
            }
            upload() {
                return this.loader.file.then(file => new Promise((resolve, reject) => {
                    const data = new FormData();
                    data.append('upload', file);
                    fetch(this.url, { method: 'POST', body: data })
                        .then(res => res.json())
                        .then(result => {
                            if (result.error) return reject(result.error.message);
                            resolve({ default: result.url });
                        })
                        .catch(() => reject('Không thể upload ảnh!'));
                }));
            }
            abort() {}
        }

        function MyUploadAdapterPlugin(editor) {
            editor.plugins.get('FileRepository').createUploadAdapter = (loader) => new MyUploadAdapter(loader);
        }

        ClassicEditor
            .create(document.querySelector('#editor-content'), {
                extraPlugins: [MyUploadAdapterPlugin],
                toolbar: [
                    'heading', '|', 'bold', 'italic', 'underline', 'link',
                    '|', 'bulletedList', 'numberedList',
                    '|', 'imageUpload', 'blockQuote', 'insertTable',
                    '|', 'undo', 'redo'
                ]
            })
            .then(editor => {
                // Đồng bộ nội dung về textarea trước khi submit (quan trọng để lưu đúng dữ liệu)
                document.querySelector('#post-form').addEventListener('submit', () => {
                    document.querySelector('#editor-content').value = editor.getData();
                });
            })
            .catch(error => console.error('Lỗi CKEditor:', error));
    </script>
}