@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">
    <h2 class="text-warning text-uppercase">CHỈNH SỬA BÀI VIẾT</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Chuyên mục</label>
                    <select asp-for="CategoryId" class="form-select"
                            asp-items="@(new SelectList(ViewBag.CategoryId, "Id", "Name"))">
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Hình ảnh hiện tại</label>
                    <div class="mb-2">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" width="150" class="img-thumbnail" />
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                    </div>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Nội dung</label>
                    <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>