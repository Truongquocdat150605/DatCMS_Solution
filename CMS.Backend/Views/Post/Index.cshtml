 * MSSV: 2123110209
 * Ngày sửa thêm: 22/05/2026
 * Tên file: Index.cshtml
 * Mô tả: Giao diện danh sách bài viết - Bài tập Buổi 03.
 * Chức năng: Hiển thị danh sách, tìm kiếm bài viết theo từ khóa và lọc theo danh mục.
 *@

@model IEnumerable<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Quản lý bài viết chuyên sâu";
}

<div class="container mt-4">
    <h2 class="text-primary text-uppercase">BÀI TẬP BUỔI 03: TRUY VẤN LINQ & THAO TÁC DỮ LIỆU</h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Nhập tiêu đề hoặc nội dung cần tìm...">
                </div>
                <div class="col-md-4">
                    <select name="categoryId" class="form-select">
                        <option value="">-- Tất cả chuyên mục --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">+ Thêm bài viết mới</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark text-center">
            <tr>
                <th>ID</th>
                <th>Tiêu đề bài viết</th>
                <th>Chuyên mục</th>
                <th>Ngày đăng</th>
                <th>Hình ảnh</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center">Không tìm thấy bài viết nào phù hợp.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@item.Id</td>
                        <td><b>@item.Title</b></td>
                        <td class="text-center">
                            <span class="badge bg-info text-dark">@item.Category?.Name</span>
                        </td>
                        <td class="text-center">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" width="70" class="rounded shadow-sm" />
                            }
                            else
                            {
                                <i class="text-muted">No Image</i>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               onclick="return confirm('M có chắc muốn xóa bài này không Đạt?')"
                               class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>