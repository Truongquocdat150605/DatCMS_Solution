@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container mt-4">
    <h2 class="text-primary text-uppercase">THÊM SẢN PHẨM MỚI</h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Số lượng tồn</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Danh mục sản phẩm</label>
                    <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductId">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Hình ảnh sản phẩm</label>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">Lưu sản phẩm</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>