@model CMS.Data.Entities.Product
/* * Người thực hiện: Trương Quốc Đạt
   * MSSV: 2123110209
   * Ngày thực hiện: 22/05/2026
   * Tên file: Edit.cshtml (Product)
   * Mô tả: Giao diện chỉnh sửa thông tin sản phẩm, hỗ trợ chọn lại danh mục.
 */

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-warning">CHỈNH SỬA SẢN PHẨM</h2>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                @* Quan trọng: Phải có Id ẩn để hệ thống biết đang sửa sản phẩm nào *@
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số lượng tồn kho</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Danh mục sản phẩm</label>
                    @* Sửa thành CategoryProductId để khớp với Entity Product.cs *@
                    <select asp-for="CategoryProductId" class="form-control" asp-items="ViewBag.CategoryProductId">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Đường dẫn hình ảnh (URL)</label>
                    <input asp-for="ImageUrl" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Cập nhật thay đổi</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}