@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-warning text-uppercase">CHỈNH SỬA SẢN PHẨM</h2>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" /> <div class="mb-3">
                    <label class="form-label font-weight-bold">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Giá bán</label>
                        <input asp-for="Price" type="number" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Số lượng</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Danh mục sản phẩm</label>
                    <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductId"></select>
                    <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Hình ảnh hiện tại</label>
                    <div class="mb-2">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" width="120" class="img-thumbnail" />
                        }
                    </div>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                    <small class="text-muted">Để trống nếu không muốn thay đổi ảnh</small>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>