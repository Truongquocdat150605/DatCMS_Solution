@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-primary text-uppercase">QUẢN LÝ SẢN PHẨM</h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">+ Thêm sản phẩm mới</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(ViewBag.CurrentSearch as string))
    {
        <div class="alert alert-info">
            Đang tìm kiếm sản phẩm theo từ khóa: <b>@(ViewBag.CurrentSearch)</b>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark text-center">
            <tr>
                <th>ID</th>
                <th>Tên sản phẩm</th>
                <th>Hình ảnh</th>
                <th>Giá bán</th>
                <th>Tồn kho</th>
                <th>Danh mục</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center">Chưa có sản phẩm nào.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@item.Id</td>
                        <td><b>@item.Name</b></td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" width="70" class="rounded shadow-sm" alt="@item.Name" />
                            }
                            else
                            {
                                <i class="text-muted">No Image</i>
                            }
                        </td>
                        <td class="text-end">@item.Price.ToString("N0") VNĐ</td>
                        <td class="text-center">@item.StockQuantity</td>
                        <td class="text-center">
                            <span class="badge bg-info text-dark">@(item.CategoryProduct?.Name ?? "N/A")</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               onclick="return confirm('M có chắc muốn xóa sản phẩm này không Đạt?')"
                               class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @{
        int pageIndex = ViewBag.PageIndex ?? 1;
        int totalPages = ViewBag.TotalPages ?? 1;
    }

    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Pagination">
            <ul class="pagination">
                <li class="page-item @(pageIndex <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(pageIndex - 1)" tabindex="-1">Trước</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == pageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(pageIndex >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(pageIndex + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
