@model IEnumerable<CMS.Data.Entities.Product>
@* /* * Người thực hiện: Trương Quốc Đạt
 * MSSV: 2123110209
 * Ngày thực hiện: 22/05/2026
 * Tên file: Index.cshtml (Product)
 * Mô tả: Danh sách sản phẩm có đầy đủ nút Thêm, Sửa, Xóa.
 */ *@

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">BÀI TẬP 4: DANH SÁCH SẢN PHẨM (PRODUCTS)</h2>
        <a asp-action="Create" class="btn btn-primary">Thêm sản phẩm mới</a>
    </div>

    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            Chưa có dữ liệu trong bảng Products. Vui lòng bấm "Thêm sản phẩm mới" hoặc nhập dữ liệu trong SSMS.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark text-center">
                <tr>
                    <th>ID</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá (VNĐ)</th>
                    <th>Tồn kho</th>
                    <th>Hình ảnh</th>
                    <th>Danh mục</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td class="text-center">@product.Id</td>
                        <td><b>@product.Name</b></td>
                        <td class="text-end">@product.Price.ToString("N0")</td>
                        <td class="text-center">@product.StockQuantity</td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" width="50" class="img-thumbnail" />
                            }
                            else
                            {
                                <span class="text-muted small">No Image</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info text-dark">@product.CategoryProduct?.Name</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@product.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('M có chắc muốn xóa sản phẩm này không?')">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>