@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-primary">BÀI TẬP 4: DANH SÁCH SẢN PHẨM (PRODUCTS)</h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            Chưa có dữ liệu trong bảng Products. Vui lòng nhập dữ liệu mẫu trong SSMS.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên sản phẩm</th>
                    <th>Mô tả</th>
                    <th>Giá (VNĐ)</th>
                    <th>Số lượng tồn</th>
                    <th>Hình ảnh</th>
                    <th>Danh mục</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Id</td>
                        <td>@product.Name</td>
                        <td>@product.Description</td>
                        <td>@product.Price.ToString("N0")</td>
                        <td>@product.StockQuantity</td>
                        <td>
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" width="60" class="img-thumbnail" />
                            }
                            else
                            {
                                <span class="text-muted">Không có ảnh</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-info">@product.CategoryProduct?.Name</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>