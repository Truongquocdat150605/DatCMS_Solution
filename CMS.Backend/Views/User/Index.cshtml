@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Danh sách thành viên";
}

<div class="container mt-4">
    <h2 class="text-primary">QUẢN LÝ NGƯỜI DÙNG</h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên đăng nhập</th>
                <th>Họ và tên</th>
                <th>Vai trò (Role)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Username</td>
                    <td>@user.FullName</td>
                    <td>
                        @{
                            string badgeClass = user.Role switch
                            {
                                "Admin" => "bg-danger",
                                "Editor" => "bg-warning",
                                "Moderator" => "bg-info",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@user.Role</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <p class="text-muted">
            <i class="bi bi-info-circle"></i>
            Lưu ý: Mật khẩu không được hiển thị vì lý do bảo mật.
        </p>
    </div>
</div>