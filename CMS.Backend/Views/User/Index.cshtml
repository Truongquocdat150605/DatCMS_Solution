@* Người thực hiện: Trương Quốc Đạt - 2123110209
   Tên file: Index.cshtml (User)
   Mô tả: Danh sách tài khoản quản trị viên hệ thống *@

@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-4">
    <h2 class="text-primary text-uppercase">
        <i class="bi bi-people-fill me-2"></i>QUẢN LÝ NGƯỜI DÙNG
    </h2>
    <p>Sinh viên: <b>Trương Quốc Đạt - 2123110209</b></p>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-person-plus-fill me-1"></i> Thêm người dùng mới
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width:60px;">ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Họ và tên</th>
                        <th>Vai trò</th>
                        <th style="width:150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                Chưa có người dùng nào trong hệ thống.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in Model)
                        {
                            string badgeClass = user.Role switch
                            {
                                "Admin"  => "bg-danger",
                                "Editor" => "bg-warning text-dark",
                                "User"   => "bg-secondary",
                                _        => "bg-secondary"
                            };
                            <tr>
                                <td class="text-center">@user.Id</td>
                                <td>
                                    <i class="bi bi-person-circle me-1 text-muted"></i>
                                    <strong>@user.Username</strong>
                                </td>
                                <td>@user.Email</td>
                                <td>@user.FullName</td>
                                <td class="text-center">
                                    <span class="badge @badgeClass px-3 py-2">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil-fill"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Bạn có chắc muốn xóa người dùng \'@user.Username\' không?');">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <p class="text-muted small">
            <i class="bi bi-shield-lock me-1"></i>
            Lưu ý: Mật khẩu không được hiển thị vì lý do bảo mật.
        </p>
    </div>
</div>
